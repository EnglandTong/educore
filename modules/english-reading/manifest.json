    { "id": "A2", "name": "Early Reader", "gradeRange": "2-3", "order": 2 },
    { "id": "B1", "name": "Developing Reader", "gradeRange": "4-5", "order": 3 },
    { "id": "B2", "name": "Proficient Reader", "gradeRange": "6-8", "order": 4 },
    { "id": "C1", "name": "Advanced Reader", "gradeRange": "9-12", "order": 5 }
