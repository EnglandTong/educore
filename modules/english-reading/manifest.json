      "order": 3
    },
    {
      "id": "inferential-comprehension",
      "name": "Inferential Comprehension",
      "description": "Make predictions, draw conclusions, and infer meaning from text",
      "subSkills": ["making-predictions", "drawing-conclusions", "cause-effect", "character-feelings", "author-purpose"],
      "order": 4
    },
    {
      "id": "critical-analysis",
      "name": "Critical Analysis",
      "description": "Analyze text structure, themes, and author's craft",
      "subSkills": ["text-structure", "theme-identification", "compare-contrast", "point-of-view", "figurative-language"],
      "order": 5
    }
  ],
  "levels": [
