# EduCore Docker Production Environment Variables
# Copy this file to .env and fill in secure values before running docker compose up

# MongoDB authentication
MONGO_USER=your-mongo-user
MONGO_PASSWORD=your-secure-password

# JWT secret (must be at least 16 characters)
JWT_SECRET=your-jwt-secret-at-least-16-chars

# CORS allowed origins (comma-separated, no spaces)
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
