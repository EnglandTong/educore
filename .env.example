# Server
PORT=4000
NODE_ENV=development
HOST=0.0.0.0

# Database
# MongoDB connection for API data and seed/index scripts.
MONGODB_URI=mongodb://localhost:27017/educore
# MongoDB authentication (production). Set these when using docker-compose with auth enabled.
# MONGO_USER=admin
# MONGO_PASSWORD=change-this-in-production
# Redis connection for auth rotation and short-lived API caches.
REDIS_URL=redis://localhost:6379

# Auth
# Replace before production. Used to sign JWT access and refresh tokens.
JWT_SECRET=change-this-in-production
# Access token lifetime for normal API calls.
JWT_ACCESS_EXPIRY=15m
# Refresh token lifetime for session rotation.
JWT_REFRESH_EXPIRY=7d

# AI (optional - system works without these, uses mock mode)
# Optional Ark API key for future AI-backed features.
ARK_API_KEY=
# Optional Ark base URL.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# Optional Ark model name.
ARK_MODEL=

# Frontend
# Public API base URL used by the frontend app.
VITE_API_URL=http://localhost:4000/api/v1

# CORS
# Comma-separated list of allowed origins for CORS.
# Default: all origins allowed (development only).
# Production example: CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=
