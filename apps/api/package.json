{
  "name": "@educore/api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:indexes": "tsx src/scripts/create-indexes.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed-demo": "tsx src/scripts/seed-demo.ts"
  },
  "dependencies": {
    "@educore/algorithms": "workspace:*",
    "@educore/constants": "workspace:*",
    "@educore/types": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "jose": "^5.8.0",
    "mongoose": "^8.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "mongodb-memory-server": "^11.1.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
